# For local wrangler dev, copy these to apps/api/.dev.vars (not .env — wrangler doesn't read .env files)
# For production, set these as Cloudflare Worker secrets/vars via the dashboard or wrangler CLI

# Better Auth
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:3001
