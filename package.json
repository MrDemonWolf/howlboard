{
  "name": "howlboard",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:api": "turbo -F api dev",
    "dev:docs": "turbo -F docs dev",
    "db:push": "turbo -F @howlboard/db db:push",
    "db:generate": "turbo -F @howlboard/db db:generate",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260312.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "tailwindcss": "^4.2.1",
    "turbo": "^2.8.16",
    "typescript": "^5"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": ["esbuild", "sharp", "workerd"]
}
